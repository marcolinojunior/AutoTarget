<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📝 Cadastro"
        android:textSize="28sp"
        android:textColor="#E94560"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crie sua conta no AutoTarget"
        android:textSize="14sp"
        android:textColor="#B0BEC5"
        android:layout_marginBottom="40dp" />

    <EditText
        android:id="@+id/etEmailCadastro"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textColor="#FFFFFF"
        android:textColorHint="#78909C"
        android:background="#16213E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etSenhaCadastro"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Senha (mín. 6 caracteres)"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#78909C"
        android:background="#16213E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnEfetuarCadastro"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cadastrar"
        android:backgroundTint="#0F3460"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnVoltarLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Já tenho conta. Voltar"
        android:backgroundTint="#333333"
        android:textColor="#B0BEC5"
        android:layout_marginBottom="24dp" />

</LinearLayout>
