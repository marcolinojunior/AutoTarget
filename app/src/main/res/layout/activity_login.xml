<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 AutoTarget"
        android:textSize="28sp"
        android:textColor="#E94560"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de Defesa Automatizado"
        android:textSize="14sp"
        android:textColor="#B0BEC5"
        android:layout_marginBottom="40dp" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textColor="#FFFFFF"
        android:textColorHint="#78909C"
        android:background="#16213E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etSenha"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Senha (mín. 6 caracteres)"
        android:inputType="textPassword"
        android:textColor="#FFFFFF"
        android:textColorHint="#78909C"
        android:background="#16213E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Entrar"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnGoogle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Entrar com Google"
        android:backgroundTint="#FFFFFF"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnAbrirCadastro"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Não tem conta? Cadastre-se"
        android:backgroundTint="#0F3460"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnAnonimo"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Entrar sem conta"
        android:backgroundTint="#333333"
        android:textColor="#B0BEC5"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 Dados protegidos por AES/GCM/NoPadding"
        android:textSize="11sp"
        android:textColor="#546E7A" />

</LinearLayout>
